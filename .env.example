# Convex (required for Next.js + Convex)
# Local dev: set by `npx convex dev`
# Vercel: set automatically by `npx convex deploy` when CONVEX_DEPLOY_KEY is configured
NEXT_PUBLIC_CONVEX_URL=https://precise-gecko-559.convex.cloud

# Vercel only: Production deploy key from Convex Dashboard > Settings > Deploy Keys
# CONVEX_DEPLOY_KEY=prod:...
